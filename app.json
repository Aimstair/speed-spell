{
  "expo": {
    "name": "Speed Spell",
    "slug": "speed-spell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1.0.0"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F3F2EE"
    },
    "android": {
      "splash": {
        "image": "./assets/transparent.png",
        "resizeMode": "cover",
        "backgroundColor": "#F3F2EE"
      },
      "adaptiveIcon": {
        "backgroundColor": "#F3F2EE",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aimteralabs.speedspell",
      "versionCode": 4,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8621446085621887~4529843924",
          "iosAppId": "ca-app-pub-8621446085621887~4529843924"
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "1b6fa3e9-4730-4b1e-9550-7de1c08e704b"
      }
    }
  }
}